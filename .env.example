# ============================================
# Indore Dental Hospital — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control
# ============================================

# --- Resend (transactional email — replaces SMTP) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=appointments@mail.indoredental.co.in

# --- Clinic Email (receives appointment notifications) ---
CLINIC_EMAIL=indoredentalhospital@gmail.com

# --- WhatsApp Business Number (with country code) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=+919XXXXXXXXX

# --- Google Maps Embed API Key ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# --- Google Analytics Measurement ID ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Rate Limiting ---
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=900000

# --- App URL (for CORS and redirects) ---
NEXT_PUBLIC_SITE_URL=https://indoredental.co.in
